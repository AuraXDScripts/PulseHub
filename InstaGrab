        task.wait(0.08)
        if AutoGrabEnabled and not IsStealing and (os.clock() - LastGrabTime >= COOLDOWN_TIME) then
            local animal = getNearestAnimal()
            if animal then
                task.wait(0.08) -- mic delay natural
                local recheck = getNearestAnimal()
